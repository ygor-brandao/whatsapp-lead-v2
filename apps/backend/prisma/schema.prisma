generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id              String   @id @default(cuid())
  messageId       String   @unique             // ID único da mensagem no WhatsApp
  groupId         String
  groupName       String
  senderNumber    String                       // Número limpo: 5511999999999
  senderName      String?
  messageText     String
  messageContext  String?                      // JSON: array das 3 msgs anteriores
  classification  String                       // "BUYER" | "SELLER" | "UNCERTAIN"
  confidence      Float
  geminiReason    String
  whatsappLink    String                       // https://wa.me/5511999999999?text=...
  status          String   @default("NEW")    // "NEW"|"CONTACTED"|"LATER"|"DISMISSED"|"REVIEWING"
  notified        Boolean  @default(false)
  scannedAt       DateTime                    // Timestamp original da mensagem
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId])
  @@index([classification])
  @@index([status])
  @@index([createdAt])
}

model GroupLink {
  id          String    @id @default(cuid())
  groupName   String?
  inviteLink  String    @unique
  foundIn     String                          // groupId onde foi encontrado
  foundBy     String                          // número que enviou o link
  foundAt     DateTime  @default(now())
  joined      Boolean   @default(false)
  joinedAt    DateTime?
}

model MonitoredGroup {
  id          String    @id @default(cuid())
  groupId     String    @unique
  groupName   String
  active      Boolean   @default(true)
  totalLeads  Int       @default(0)
  lastScanned DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScanJob {
  id           String    @id @default(cuid())
  status       String    @default("PENDING") // "PENDING"|"RUNNING"|"DONE"|"FAILED"
  targetCount  Int                           // Quantidade solicitada pelo usuário
  processed    Int       @default(0)
  found        Int       @default(0)         // Leads encontrados
  groupId      String?                       // null = todos os grupos
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model ConnectionStatus {
  id          String   @id @default("singleton")
  status      String   // "CONNECTED"|"DISCONNECTED"|"RECONNECTING"|"QR_PENDING"
  retryCount  Int      @default(0)
  lastSeen    DateTime?
  updatedAt   DateTime @updatedAt
}
