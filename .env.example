# ─── SUPABASE ───────────────────────────────────────────────────────────────
# Onde criar: https://supabase.com → New Project (região: sa-east-1)
# Onde pegar as chaves: Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Onde pegar: Dashboard → Settings → Database → Transaction Pooler
DATABASE_URL=postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:6543/postgres
# Onde pegar: mesma página → Direct Connection
DIRECT_URL=postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── GOOGLE GEMINI ──────────────────────────────────────────────────────────
# Onde criar: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ─── EVOLUTION API ──────────────────────────────────────────────────────────
# SEMPRE a URL do serviço no Render — não existe localhost neste projeto
EVOLUTION_API_URL=https://evolution-leadwatcher.onrender.com
# A mesma chave definida nas env vars do serviço Evolution no Render
EVOLUTION_API_KEY=chave-secreta-forte-gerada-com-openssl-rand-hex-32
# Nome da instância (o mesmo usado no POST /instance/create)
EVOLUTION_INSTANCE_NAME=leadwatcher

# ─── REDIS (UPSTASH) ────────────────────────────────────────────────────────
# Onde criar: https://console.upstash.com → Create Database → Redis → Free
REDIS_URL=rediss://default:TOKEN@ENDPOINT.upstash.io:6379

# ─── CONFIGURAÇÕES GERAIS ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
# Segredo para validar que o webhook veio da Evolution API (definir o mesmo no Render)
WEBHOOK_SECRET=segredo-forte-gerado-com-openssl-rand-hex-32

# ─── DASHBOARD (NEXT.JS — prefixo obrigatório NEXT_PUBLIC_) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# URL do backend em produção no Render
NEXT_PUBLIC_API_URL=https://leadwatcher-backend.onrender.com
